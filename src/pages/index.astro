---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import Story from "../components/sections/Story.astro";
import Menu from "../components/sections/Menu.astro";
import GalleryTeaser from "../components/sections/GalleryTeaser.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Visit from "../components/sections/Visit.astro";
import { site } from "../data/site";

const lang = "de" as const;
---

<Base
  title={`${site.fullName} — Spezialitätenkaffee, Matcha & Kunst in Hamburg`}
  description="Spezialitätenkaffee, zeremonieller Matcha & wechselnde Kunst im Hamburger Schanzenviertel."
  lang={lang}
  path="/"
>
  <Header slot="header" page="home" lang={lang} />

  <Hero lang={lang} />
  <Story lang={lang} />
  <Menu lang={lang} />
  <GalleryTeaser lang={lang} />
  <Testimonials lang={lang} />
  <Visit lang={lang} />

  <Footer slot="footer" lang={lang} />
</Base>
