---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import Story from "../components/sections/Story.astro";
import Menu from "../components/sections/Menu.astro";
import GalleryTeaser from "../components/sections/GalleryTeaser.astro";
import Visit from "../components/sections/Visit.astro";
import { site } from "../data/site";
---

<Base title={`${site.fullName} — Specialty Coffee, Matcha & Art in Hamburg`} page="home">
  <Header slot="header" page="home" />

  <Hero />
  <Story />
  <Menu />
  <GalleryTeaser />
  <Visit />

  <Footer slot="footer" />
</Base>
