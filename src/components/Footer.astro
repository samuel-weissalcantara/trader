---
import { site } from "../data/site";
import { getContent, localePath, type Lang } from "../data/i18n";
import Mark from "./Mark.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang);
---

<footer class="site-footer">
  <div class="wrap grid">
    <div class="col brand">
      <p class="wordmark"><Mark size="1.6em" class="mark" />TRADER<span>Gallery</span></p>
      <p class="tag">{t.hero.tagline}</p>
      <a class="ig" href={site.instagram} target="_blank" rel="noopener">{site.instagramHandle} ↗</a>
    </div>

    <div class="col">
      <p class="col-title">{t.footer.visitTitle}</p>
      <address>
        {site.address.street}<br />
        {site.address.postal} {site.address.city}<br />
        {site.address.district}
      </address>
      <a class="link" href={site.mapsUrl} target="_blank" rel="noopener">{t.footer.directions}</a>
    </div>

    <div class="col">
      <p class="col-title">{t.footer.hoursTitle}</p>
      <ul>
        {t.visit.hoursDisplay.map((h) => (
          <li><span>{h.label}</span><span>{h.value}</span></li>
        ))}
      </ul>
    </div>

    <div class="col">
      <p class="col-title">{t.footer.exploreTitle}</p>
      <ul class="links">
        <li><a href={`${localePath(lang, "/")}#story`}>{t.nav.story}</a></li>
        <li><a href={`${localePath(lang, "/")}#menu`}>{t.nav.menu}</a></li>
        <li><a href={localePath(lang, "/gallery")}>{t.nav.gallery}</a></li>
        <li><a href={`${localePath(lang, "/")}#visit`}>{t.nav.visit}</a></li>
      </ul>
    </div>

    <div class="col">
      <p class="col-title">{t.footer.legalTitle}</p>
      <ul class="links">
        <li><a href={localePath(lang, "/impressum")}>{t.footer.impressum}</a></li>
        <li><a href={localePath(lang, "/datenschutz")}>{t.footer.datenschutz}</a></li>
      </ul>
    </div>
  </div>

  <div class="wrap bottom">
    <p>© {new Date().getFullYear()} TRADER, Hamburg.</p>
    <p>{site.priceRange} {t.footer.perPerson} · ★ {site.rating.value} ({site.rating.count} {t.footer.reviews})</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--chip);
    color: var(--on-chip);
    padding-block: clamp(3rem, 6vw, 5rem) 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 3rem);
  }

  .brand .wordmark {
    font-family: var(--font-display);
    font-size: 1.6rem;
    margin: 0 0 0.3em;
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  :global(.brand .wordmark .mark) {
    flex-shrink: 0;
    border-radius: 50%;
  }

  .brand .wordmark span {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b9c39e;
    margin-left: 0.6em;
  }

  .tag {
    color: #cfc6b6;
    max-width: 26ch;
  }

  .ig {
    color: #b9c39e;
    text-decoration: none;
    font-weight: 600;
  }

  .col-title {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9c9384;
    margin-bottom: 1em;
  }

  address {
    font-style: normal;
    color: #e6dfd0;
    margin-bottom: 0.9em;
    line-height: 1.6;
  }

  .link,
  .links a {
    color: #e6dfd0;
    text-decoration: none;
  }

  .link:hover,
  .links a:hover {
    color: var(--sage);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .col ul:not(.links) li {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    color: #cfc6b6;
    padding-block: 0.25em;
    font-size: 0.9rem;
    border-bottom: 1px solid rgba(244, 239, 230, 0.08);
  }

  .links li {
    margin-bottom: 0.6em;
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5em;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(244, 239, 230, 0.12);
    font-size: 0.82rem;
    color: #9c9384;
  }

  .bottom p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 420px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
