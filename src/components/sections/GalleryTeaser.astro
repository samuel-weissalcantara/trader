---
import Frame from "../Frame.astro";
import { galleryImages, exhibition } from "../../data/site";
import { getContent, localePath, type Lang } from "../../data/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang);
const preview = galleryImages.slice(0, 4).map((img) => {
  const text = t.galleryPage.images.find((i) => i.id === img.id)!;
  return { ...img, ...text, categoryLabel: t.galleryPage.categories[img.category] };
});
const galleryHref = localePath(lang, "/gallery");
---

<section class="section-tight gallery-teaser">
  <div class="wrap">
    <div class="teaser-head reveal" data-reveal>
      <div>
        <p class="eyebrow">{t.galleryTeaser.eyebrow}</p>
        <h2>{t.galleryTeaser.heading}</h2>
      </div>
      <a class="btn btn-outline" href={galleryHref}>{t.galleryTeaser.viewFull}</a>
    </div>

    <div class="teaser-grid reveal" data-reveal>
      {preview.map((img, i) => (
        <a href={galleryHref} class={`teaser-cell cell-${i}`}>
          <Frame src={img.src} alt={img.alt} ratio="1 / 1" label={img.categoryLabel} />
        </a>
      ))}

      <a href={galleryHref} class="exhibition-card">
        <p class="eyebrow">{t.galleryPage.exhibitionEyebrow}</p>
        <h3>{exhibition.title}</h3>
        <p class="artist">{exhibition.artist}</p>
        <p class="dates">{t.galleryPage.exhibitionDatesLabel}</p>
        <span class="link">{t.galleryTeaser.seeExhibition}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .teaser-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
    flex-wrap: wrap;
  }

  .teaser-head h2 {
    margin-top: 0.2em;
  }

  .teaser-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(2, minmax(140px, auto));
    gap: 0.8rem;
  }

  .teaser-cell {
    display: block;
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.4s var(--ease);
  }

  .teaser-cell:hover {
    transform: translateY(-4px);
  }

  .cell-0 {
    grid-column: span 2;
    grid-row: span 2;
  }
  .cell-1 {
    grid-column: span 1;
  }
  .cell-2 {
    grid-column: span 1;
  }
  .cell-3 {
    grid-column: span 1;
    grid-row: span 2;
  }

  .exhibition-card {
    grid-column: span 1;
    grid-row: span 1;
    background: var(--chip);
    color: var(--on-chip);
    border-radius: 4px;
    padding: 1.2em;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15em;
  }

  .exhibition-card .eyebrow {
    color: #b9c39e;
  }

  .exhibition-card h3 {
    margin: 0.1em 0 0;
    font-size: 1.15rem;
  }

  .exhibition-card .artist {
    color: #cfc6b6;
    margin: 0;
    font-size: 0.85rem;
  }

  .exhibition-card .dates {
    color: #9c9384;
    font-size: 0.75rem;
    margin: 0.4em 0 0.8em;
  }

  .exhibition-card .link {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sage);
  }

  @media (max-width: 900px) {
    .teaser-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }
    .cell-0,
    .cell-3 {
      grid-row: auto;
    }
  }
</style>
