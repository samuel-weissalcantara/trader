---
import { TurntableHero } from "../ui/turntable-hero";
import { getContent, type Lang } from "../../data/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang);
---

<TurntableHero
  client:load
  eyebrow={t.hero.eyebrow}
  headlinePart1={t.hero.overlayPart1}
  headlinePart2={t.hero.overlayPart2}
/>
