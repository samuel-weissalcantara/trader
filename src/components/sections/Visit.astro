---
import OpenStatus from "../OpenStatus.astro";
import { site } from "../../data/site";
import { getContent, localePath, type Lang } from "../../data/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang);

// Keyless Google Maps embed (the `output=embed` form works without an API
// key, unlike the Maps Embed API's /maps/embed/v1/place endpoint). Not
// loaded until the user clicks through the consent gate below — an iframe
// with a `src` starts the request to Google the moment it's in the DOM,
// consent or not, so the gate has to keep the src out of markup entirely
// until then (see the script at the bottom of this file).
const mapEmbedSrc = `https://www.google.com/maps?q=${site.address.lat},${site.address.lng}&z=16&output=embed`;
const mapTitle = `Karte: ${site.fullName}, ${site.address.street}`;
---

<section id="visit" class="section visit">
  <div class="wrap visit-grid">
    <div class="visit-map reveal" data-reveal>
      <div class="map-gate" data-map-gate data-src={mapEmbedSrc} data-title={mapTitle}>
        <p class="map-gate-text">
          {t.visit.mapConsent.text}
          {" "}
          <a href={localePath(lang, "/datenschutz")}>{t.visit.mapConsent.linkLabel}</a>
        </p>
        <button type="button" class="btn btn-outline" data-map-gate-button>{t.visit.mapConsent.button}</button>
      </div>
    </div>

    <div class="visit-copy reveal" data-reveal>
      <p class="eyebrow">{t.visit.eyebrow}</p>
      <h2>{t.visit.heading}</h2>

      <div class="visit-block">
        <h3>{t.visit.addressTitle}</h3>
        <p>{site.address.street}<br />{site.address.postal} {site.address.city}</p>
        <p class="hint">{t.visit.transitHint}</p>
      </div>

      <div class="visit-block">
        <h3>{t.visit.hoursTitle}</h3>
        <ul class="hours-list">
          {t.visit.hoursDisplay.map((h) => (
            <li><span>{h.label}</span><span>{h.value}</span></li>
          ))}
        </ul>
        <div class="status-row"><OpenStatus lang={lang} /></div>
      </div>

      <div class="visit-ctas">
        <a class="btn btn-primary" href={site.mapsUrl} target="_blank" rel="noopener">{t.visit.ctaDirections}</a>
        <a class="btn btn-outline" href={site.instagram} target="_blank" rel="noopener">{site.instagramHandle}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .visit-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .visit-map {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
  }

  .visit-map :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    /* Dark-mode-ify the (always-light) Google Maps iframe so it doesn't
       clash with the site's dark coffee-brown palette. */
    filter: grayscale(0.35) invert(0.9) contrast(0.92) brightness(0.95) hue-rotate(180deg);
  }

  .map-gate {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.2em;
    text-align: center;
    padding: 2em;
    background: linear-gradient(135deg, var(--paper-dim), var(--surface));
  }

  .map-gate-text {
    max-width: 26em;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  .map-gate-text a {
    color: var(--sage);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .visit-block {
    margin-bottom: 1.8em;
  }

  .visit-block h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5em;
  }

  .hint {
    color: var(--sage);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .hours-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 26rem;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding-block: 0.5em;
    border-bottom: 1px solid var(--line);
    font-size: 0.92rem;
  }

  .status-row {
    margin-top: 1em;
  }

  .visit-ctas {
    display: flex;
    gap: 1em;
    flex-wrap: wrap;
    margin-top: 2em;
  }

  @media (max-width: 900px) {
    .visit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-map-gate]").forEach((gate) => {
    const button = gate.querySelector<HTMLButtonElement>("[data-map-gate-button]");
    button?.addEventListener("click", () => {
      const iframe = document.createElement("iframe");
      iframe.src = gate.dataset.src ?? "";
      iframe.title = gate.dataset.title ?? "";
      iframe.loading = "lazy";
      iframe.referrerPolicy = "no-referrer-when-downgrade";
      gate.replaceWith(iframe);
    });
  });
</script>
