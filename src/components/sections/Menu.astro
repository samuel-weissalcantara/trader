---
import Marquee from "../Marquee.astro";
import Frame from "../Frame.astro";
import { menuPrices, matchaSignatureIndex } from "../../data/site";
import { getContent, type Lang } from "../../data/i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang).menu;

const groups = [
  { title: t.groupTitles.coffee, items: t.coffee.map((item, i) => ({ ...item, price: menuPrices.coffee[i] })) },
  {
    title: t.groupTitles.matcha,
    items: t.matcha.map((item, i) => ({ ...item, price: menuPrices.matcha[i], signature: i === matchaSignatureIndex })),
  },
  { title: t.groupTitles.pastries, items: t.pastries.map((item, i) => ({ ...item, price: menuPrices.pastries[i] })) },
];
---

<section id="menu" class="section-tight">
  <Marquee lang={lang} />

  <div class="wrap section">
    <div class="section-head reveal" data-reveal>
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.heading}</h2>
      <p>{t.description}</p>
    </div>

    <div class="menu-grid">
      {groups.map((group) => (
        <div class="menu-col reveal" data-reveal>
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => (
              <li class:list={["menu-item", { signature: "signature" in item && item.signature }]}>
                {"signature" in item && item.signature && (
                  <Frame class="signature-photo" src="placeholder:coffee:2" alt={item.name} ratio="1 / 1" />
                )}
                <div class="menu-item-body">
                  <div class="menu-item-head">
                    <span class="name">
                      {item.name}
                      {"signature" in item && item.signature && <span class="badge">{t.signatureBadge}</span>}
                    </span>
                    <span class="price">{item.price}</span>
                  </div>
                  <p class="desc">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 5vw, 3rem);
  }

  .menu-col h3 {
    margin-bottom: 0.9em;
    padding-bottom: 0.6em;
    border-bottom: 2px solid var(--ink);
  }

  .menu-item {
    padding-block: 1em;
    border-bottom: 1px solid var(--line);
  }

  .menu-item:last-child {
    border-bottom: none;
  }

  .menu-item.signature {
    background: linear-gradient(90deg, rgba(124, 138, 90, 0.09), transparent);
    margin-inline: -0.8em;
    padding-inline: 0.8em;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 1em;
  }

  :global(.signature-photo) {
    width: 4.2em;
    flex-shrink: 0;
    border-radius: 4px;
  }

  .menu-item-body {
    flex: 1;
    min-width: 0;
  }

  .menu-item-head {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    align-items: baseline;
  }

  .name {
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
  }

  .badge {
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--sage-dark);
    color: var(--on-chip);
    padding: 0.25em 0.55em;
    border-radius: 999px;
    font-weight: 700;
  }

  .price {
    font-variant-numeric: tabular-nums;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .desc {
    margin: 0.3em 0 0;
    font-size: 0.88rem;
  }

  @media (max-width: 900px) {
    .menu-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .menu-item.signature {
      flex-wrap: wrap;
      margin-inline: 0;
      padding-inline: 0.6em;
    }

    :global(.signature-photo) {
      width: 3.4em;
    }
  }
</style>
