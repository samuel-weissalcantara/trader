---
import { site } from "../data/site";
import { getContent, localePath, type Lang } from "../data/i18n";
import Mark from "./Mark.astro";

interface Props {
  page?: "home" | "gallery" | "legal";
  lang: Lang;
  /** Unprefixed path of the equivalent page in the other language, e.g. "/gallery" or "/impressum". Defaults to "/". */
  altPath?: string;
}
const { page = "home", lang, altPath = page === "gallery" ? "/gallery" : "/" } = Astro.props;
const t = getContent(lang);
const homeHref = (anchor: string) => (page === "home" ? anchor : `${localePath(lang, "/")}${anchor}`);
const otherLang: Lang = lang === "de" ? "en" : "de";
---

<header class="site-header">
  <div class="wrap bar">
    <a href={localePath(lang, "/")} class="wordmark" aria-label="TRADER home">
      <Mark size="1.8em" class="mark" />
      TRADER
      <span class="wordmark-sub">Gallery</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href={homeHref("#story")}>{t.nav.story}</a>
      <a href={homeHref("#menu")}>{t.nav.menu}</a>
      <a href={localePath(lang, "/gallery")} aria-current={page === "gallery" ? "page" : undefined}>{t.nav.gallery}</a>
      <a href={homeHref("#visit")}>{t.nav.visit}</a>
    </nav>

    <div class="actions">
      <a class="lang-switch" href={localePath(otherLang, altPath)} hreflang={otherLang}>
        {otherLang.toUpperCase()}
      </a>
      <a class="btn btn-primary btn-visit" href={homeHref("#visit")}>{t.nav.planVisit}</a>
      <button class="menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" data-menu-toggle>
        <span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" data-mobile-nav aria-label="Mobile">
    <a href={homeHref("#story")}>{t.nav.story}</a>
    <a href={homeHref("#menu")}>{t.nav.menu}</a>
    <a href={localePath(lang, "/gallery")}>{t.nav.gallery}</a>
    <a href={homeHref("#visit")}>{t.nav.visit}</a>
    <a href={localePath(otherLang, altPath)} hreflang={otherLang}>
      {otherLang === "de" ? "Deutsch" : "English"}
    </a>
    <a class="btn btn-primary" href={homeHref("#visit")}>{t.nav.planVisit}</a>
    <a class="ig-link" href={site.instagram} target="_blank" rel="noopener">{site.instagramHandle}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(245, 239, 226, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1em;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  :global(.wordmark .mark) {
    flex-shrink: 0;
    border-radius: 50%;
  }

  .wordmark-sub {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage-dark);
    font-weight: 700;
  }

  .nav {
    display: flex;
    gap: 2.1em;
  }

  .nav a {
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-soft);
    position: relative;
    padding-block: 0.2em;
  }

  .nav a:hover,
  .nav a[aria-current="page"] {
    color: var(--ink);
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--sage-dark);
    transition: width 0.25s var(--ease);
  }

  .nav a:hover::after {
    width: 100%;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 1em;
  }

  .lang-switch {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.4em 0.75em;
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .lang-switch:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  .btn-visit {
    padding: 0.65em 1.3em;
    font-size: 0.85rem;
  }

  .menu-toggle {
    display: none;
    width: 2.4em;
    height: 2.4em;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: transparent;
    position: relative;
    cursor: pointer;
  }

  .menu-toggle span,
  .menu-toggle span::before,
  .menu-toggle span::after {
    content: "";
    position: absolute;
    left: 26%;
    right: 26%;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.25s var(--ease), opacity 0.25s var(--ease);
  }

  .menu-toggle span {
    top: 50%;
  }

  .menu-toggle span::before {
    top: -6px;
  }

  .menu-toggle span::after {
    top: 6px;
  }

  .menu-toggle[aria-expanded="true"] span {
    background: transparent;
  }

  .menu-toggle[aria-expanded="true"] span::before {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] span::after {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 1.3em;
    padding: 1.5em var(--gutter) 2.2em;
    border-top: 1px solid var(--line);
  }

  .mobile-nav a {
    text-decoration: none;
    color: var(--ink);
    font-size: 1.05rem;
    font-weight: 500;
  }

  .mobile-nav .ig-link {
    color: var(--sage-dark);
    font-weight: 600;
  }

  .mobile-nav.is-open {
    display: flex;
  }

  @media (max-width: 780px) {
    .nav,
    .btn-visit {
      display: none;
    }
    .menu-toggle {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", String(!!isOpen));
  });
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      nav.classList.remove("is-open");
      toggle?.setAttribute("aria-expanded", "false");
    })
  );

  // Expose the real rendered header height as a CSS var so sections that
  // need to fill "the rest of the viewport" (the hero) can size against it
  // without guessing — the header's height varies slightly by content/zoom.
  const header = document.querySelector<HTMLElement>(".site-header");
  function setHeaderHeight() {
    if (header) {
      document.documentElement.style.setProperty("--header-h", `${header.offsetHeight}px`);
    }
  }
  setHeaderHeight();
  window.addEventListener("resize", setHeaderHeight, { passive: true });
</script>
