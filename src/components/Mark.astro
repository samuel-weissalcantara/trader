---
// TRADER's real logo mark from Instagram: a black disc, an off-center ring
// (evoking a cup rim seen from above), and "TRADER" set into the lower arc.
interface Props {
  size?: string;
  class?: string;
}
const { size = "1em", class: className = "" } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="50" cy="50" r="50" fill="var(--sage-dark)" />
  <circle cx="50" cy="41" r="21" fill="none" stroke="var(--ink)" stroke-width="11" />
  <text
    x="50"
    y="80"
    text-anchor="middle"
    font-family="Helvetica, Arial, sans-serif"
    font-weight="700"
    font-size="14"
    letter-spacing="1.5"
    fill="var(--ink)">TRADER</text>
</svg>
