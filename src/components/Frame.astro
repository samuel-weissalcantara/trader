---
// Placeholder-aware image frame.
// Pass a real image path (e.g. "/images/hero.jpg") once photography is available —
// anything starting with "placeholder:" renders an art-directed placeholder instead,
// so swapping real photos in later is a one-line change per entry in src/data/site.ts.

interface Props {
  src: string;
  alt: string;
  ratio?: string; // e.g. "4 / 5"
  label?: string;
  class?: string;
  eager?: boolean;
}

const { src, alt, ratio = "4 / 5", label, class: className = "", eager = false } = Astro.props;
const isPlaceholder = src.startsWith("placeholder:");
const [, category = "Space", seed = "1"] = src.split(":");

const palettes: Record<string, [string, string]> = {
  Space: ["#3a281e", "#6a543d"],
  Coffee: ["#261d16", "#8a6f4f"],
  Art: ["#502614", "#6a543d"],
  People: ["#402f23", "#bca089"],
};
const [c1, c2] = palettes[category] ?? palettes.Space;
const angle = (Number(seed) * 47) % 360;
---

{
  isPlaceholder ? (
    <div
      class={`frame frame-placeholder ${className}`}
      style={`--ratio:${ratio}; --c1:${c1}; --c2:${c2}; --angle:${angle}deg;`}
      role="img"
      aria-label={alt}
    >
      <span class="frame-grain" aria-hidden="true" />
      {label && <span class="frame-label">{label}</span>}
    </div>
  ) : (
    <div class={`frame ${className}`} style={`--ratio:${ratio};`}>
      <img src={src} alt={alt} loading={eager ? "eager" : "lazy"} decoding="async" />
    </div>
  )
}

<style>
  .frame {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    border-radius: 4px;
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .frame-placeholder {
    background: linear-gradient(var(--angle), var(--c1), var(--c2));
  }

  .frame-grain {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    background-size: 180px 180px;
  }

  .frame-label {
    position: absolute;
    left: 0.9em;
    bottom: 0.8em;
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(244, 239, 230, 0.85);
    background: rgba(33, 28, 22, 0.35);
    padding: 0.3em 0.7em;
    border-radius: 999px;
    backdrop-filter: blur(3px);
  }
</style>
