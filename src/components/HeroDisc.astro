---
// The big opening visual — recreated from the reference icon you shared
// (a cup-and-handle silhouette read as a coffee cup), recolored to the
// site's warm brown/tan palette via CSS custom properties so it stays
// theme-driven rather than hardcoded.
---

<div class="hero-disc" data-hero-disc>
  <svg viewBox="0 0 1024 1024" role="img" aria-label="">
    <path
      d="M509.75744 514.75456m-494.11072 0a494.11072 494.11072 0 1 0 988.22144 0 494.11072 494.11072 0 1 0-988.22144 0Z"
      fill="var(--sage-dark)" />
    <path
      d="M509.75744 170.14784c-169.84576 0-309.92896 128.0768-332.97408 294.4H103.22944a48.10752 48.10752 0 0 0 0 96.21504h73.55392c23.04512 166.3232 163.12832 294.4 332.97408 294.4 185.93792 0 336.67584-153.344 336.67584-342.50752 0-189.1584-150.7328-342.50752-336.67584-342.50752z"
      fill="var(--paper)" />
    <path
      d="M509.75744 512.65536m-255.04256 0a255.04256 255.04256 0 1 0 510.08512 0 255.04256 255.04256 0 1 0-510.08512 0Z"
      fill="var(--clay)" />
    <path
      d="M688.51712 331.392c-0.6656-0.63488-1.40288-1.15712-2.0736-1.78688l-351.77984 368.98816c0.66048 0.64 1.21344 1.35168 1.88416 1.98656 101.94944 97.19296 263.38304 93.3376 360.58112-8.61184 97.19296-101.94432 93.3376-263.38304-8.61184-360.576z"
      fill="var(--sage-dark)" />
  </svg>
</div>

<style>
  .hero-disc {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1;
    transform: scale(var(--disc-scale, 1)) rotate(var(--disc-rotate, 0deg));
    transform-origin: center;
    will-change: transform;
    filter: drop-shadow(0 30px 50px rgba(36, 28, 18, 0.25));
  }

  .hero-disc svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-disc {
      transform: none !important;
    }
  }
</style>
