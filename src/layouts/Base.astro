---
import "../styles/global.css";
import { site } from "../data/site";
import { localePath, type Lang } from "../data/i18n";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  /** Unprefixed path, e.g. "/" or "/gallery" or "/impressum", used to build hreflang alternates. */
  path: string;
}

const { title, description, lang, path } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const deUrl = new URL(localePath("de", path), Astro.site);
const enUrl = new URL(localePath("en", path), Astro.site);

const ogImageUrl = new URL("og-image.jpg", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  name: site.fullName,
  servesCuisine: "Coffee, Matcha, Pastries",
  image: ogImageUrl.toString(),
  priceRange: site.priceRange,
  telephone: "",
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    postalCode: site.address.postal,
    addressLocality: site.address.city,
    addressCountry: "DE",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: site.address.lat,
    longitude: site.address.lng,
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday"], opens: "08:00", closes: "18:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Saturday", "Sunday"], opens: "09:00", closes: "18:00" },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: site.rating.value,
    reviewCount: site.rating.count,
  },
  sameAs: [site.instagram],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="de" href={deUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={deUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_GB"} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Set synchronously, before paint, so the reveal-on-scroll CSS only
      // hides content once we know JS (and therefore the observer) is running.
      document.documentElement.classList.add("has-js");
    </script>
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    <script>
      import "../scripts/reveal";
    </script>
  </body>
</html>
